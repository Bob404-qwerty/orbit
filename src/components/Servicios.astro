---
interface Servicio {
  titulo: string;
  desc: string;
  tags: string[];
  svg: string;
  color: string;
}

const servicios: Servicio[] = [
  {
    titulo: "Desarrollo Web",
    desc: "Sitios web rápidos, modernos y optimizados para distintos dispositivos.",
    tags: ["Astro", "React", "Node.js"],
    svg: "M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0 0 2.5-3.5M5.2 7.2l3.3 2M5.2 16.8l3.3-2M18.8 7.2l-3.3 2M18.8 16.8l-3.3-2M12 3v3m0 12v3M3 12h3m12 0h3",
    color: "brand"
  },
  {
    titulo: "Aplicaciones",
    desc: "Aplicaciones enfocadas en experiencia de usuario y rendimiento.",
    tags: ["Flutter", "React Native"],
    svg: "M10 6h8M10 18h8M6 6v.01M6 18v.01M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z",
    color: "cyan"
  },
  {
    titulo: "Infraestructura",
    desc: "Implementación y organización de entornos cloud y despliegues.",
    tags: ["AWS", "Docker"],
    svg: "M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257A3.75 3.75 0 0 0 15.75 9h-1.5A5.25 5.25 0 0 0 2.25 15Z",
    color: "purple"
  },
  {
    titulo: "Automatización",
    desc: "Procesos automatizados para optimizar tareas y flujos de trabajo.",
    tags: ["Python", "APIs"],
    svg: "M4.5 12a7.5 7.5 0 0 0 15 0m-15 0a7.5 7.5 0 1 1 15 0m-15 0H3m16.5 0H21m-7.5 0V3m0 9v6",
    color: "emerald"
  },
  {
    titulo: "Seguridad",
    desc: "Buenas prácticas y revisión de entornos para mejorar la seguridad.",
    tags: ["OWASP", "Auditorías"],
    svg: "M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z",
    color: "rose"
  },
  {
    titulo: "Consultoría",
    desc: "Acompañamiento técnico para proyectos y decisiones tecnológicas.",
    tags: ["Arquitectura", "Optimización"],
    svg: "M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18",
    color: "amber"
  }
];
---

<section
  id="servicios"
  class="relative px-6 py-24 border-t border-white/5 overflow-hidden"
>

  <div
    class="absolute inset-0 opacity-[0.02] pointer-events-none"
    style="background-image:
    linear-gradient(rgba(255,255,255,1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px);
    background-size: 72px 72px;"
  ></div>

  <div class="max-w-6xl mx-auto relative z-10">

    <div class="mb-16 max-w-2xl">
      <span class="text-sm text-brand-400 block mb-4 tracking-wide uppercase">
        Servicios
      </span>
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight leading-tight bg-gradient-to-br from-white to-zinc-400 bg-clip-text text-transparent">
        Tecnología enfocada
        en proyectos reales.
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {servicios.map((s, i) => (
        <div
          class:list={[
            "group relative border border-white/5 bg-dark-800 rounded-2xl p-7 transition-all duration-300 hover:border-brand-500/30 hover:-translate-y-1 hover:shadow-[0_0_30px_-12px] hover:shadow-brand-500/20",
            i === 1 ? "lg:-mt-4" : "",
            i === 2 ? "lg:mt-6" : "",
          ]}
        >

          <div
            class="absolute -inset-px rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
            style="background: radial-gradient(180px at 50% 0%, rgba(139,92,246,0.08), transparent)"
          ></div>

          <div
            class:list={[
              "relative w-12 h-12 rounded-xl flex items-center justify-center mb-6 transition-colors duration-300",
              s.color === "brand" ? "bg-brand-500/10 text-brand-400" : "",
              s.color === "cyan" ? "bg-cyan-500/10 text-cyan-400" : "",
              s.color === "purple" ? "bg-purple-500/10 text-purple-400" : "",
              s.color === "emerald" ? "bg-emerald-500/10 text-emerald-400" : "",
              s.color === "rose" ? "bg-rose-500/10 text-rose-400" : "",
              s.color === "amber" ? "bg-amber-500/10 text-amber-400" : "",
            ]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
              <path d={s.svg} />
            </svg>
          </div>

          <h3 class="relative text-xl font-semibold mb-3">{s.titulo}</h3>

          <p class="relative text-zinc-400 text-sm leading-relaxed mb-6">{s.desc}</p>

          <div class="relative flex flex-wrap gap-2">
            {s.tags.map((tag) => (
              <span
                class:list={[
                  "text-xs px-2.5 py-1 rounded-md border transition-colors duration-300",
                  s.color === "brand" ? "text-brand-400/80 border-brand-500/15 bg-brand-500/5" : "",
                  s.color === "cyan" ? "text-cyan-400/80 border-cyan-500/15 bg-cyan-500/5" : "",
                  s.color === "purple" ? "text-purple-400/80 border-purple-500/15 bg-purple-500/5" : "",
                  s.color === "emerald" ? "text-emerald-400/80 border-emerald-500/15 bg-emerald-500/5" : "",
                  s.color === "rose" ? "text-rose-400/80 border-rose-500/15 bg-rose-500/5" : "",
                  s.color === "amber" ? "text-amber-400/80 border-amber-500/15 bg-amber-500/5" : "",
                ]}
              >
                {tag}
              </span>
            ))}
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
