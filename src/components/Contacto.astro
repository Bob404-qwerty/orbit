<section
  id="contacto"
  class="px-6 py-24 border-t border-white/5"
>

  <div class="max-w-5xl mx-auto">

    <div class="mb-14 max-w-2xl">

      <span class="text-sm text-brand-400 block mb-4">
        Contacto
      </span>

      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight mb-5">

        Hablemos sobre tu proyecto.

      </h2>

      <p class="text-zinc-400 text-lg leading-relaxed">

        Cuéntanos qué necesitas y revisaremos
        la mejor forma de ayudarte.

      </p>

    </div>

    <div class="grid lg:grid-cols-2 gap-10">

      <!-- FORM -->

      <form class="space-y-5">

        <div>

          <label class="text-sm text-zinc-500 block mb-2">
            Nombre
          </label>

          <input
            type="text"
            placeholder="Tu nombre"
            class="w-full h-12 bg-dark-800 border border-white/5 rounded-xl px-4 text-sm outline-none focus:border-brand-500/40 transition-colors"
          />

        </div>

        <div>

          <label class="text-sm text-zinc-500 block mb-2">
            Correo
          </label>

          <input
            type="email"
            placeholder="correo@empresa.com"
            class="w-full h-12 bg-dark-800 border border-white/5 rounded-xl px-4 text-sm outline-none focus:border-brand-500/40 transition-colors"
          />

        </div>

        <div>

          <label class="text-sm text-zinc-500 block mb-2">
            Proyecto
          </label>

          <textarea
            rows="6"
            placeholder="Cuéntanos sobre tu proyecto..."
            class="w-full bg-dark-800 border border-white/5 rounded-xl px-4 py-3 text-sm outline-none resize-none focus:border-brand-500/40 transition-colors"
          ></textarea>

        </div>

        <button
          class="bg-brand-500 hover:bg-brand-600 text-white px-6 py-3 rounded-xl text-sm font-medium transition-colors"
        >
          Enviar mensaje
        </button>

      </form>

      <!-- INFO -->

      <div class="space-y-8">

        <div class="border border-white/5 bg-dark-800 rounded-2xl p-6">

          <p class="text-sm text-zinc-500 mb-2">
            Correo
          </p>

          <p class="text-zinc-300">
            hola@orbittech.co
          </p>

        </div>

        <div class="border border-white/5 bg-dark-800 rounded-2xl p-6">

          <p class="text-sm text-zinc-500 mb-2">
            Ubicación
          </p>

          <p class="text-zinc-300">
            Bogotá, Colombia
          </p>

        </div>

        <div class="border border-white/5 bg-dark-800 rounded-2xl p-6">

          <p class="text-sm text-zinc-500 mb-2">
            Horario
          </p>

          <p class="text-zinc-300">
            Lunes a viernes — 8:00am a 6:00pm
          </p>

        </div>

      </div>

    </div>

  </div>

</section>